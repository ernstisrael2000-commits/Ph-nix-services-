{
  "entities": {
    "parcel": {
      "title": "Parcel",
      "description": "Represents a parcel being tracked in the system.",
      "type": "object",
      "properties": {
        "trackingNumber": {
          "type": "string",
          "description": "Unique tracking number for the parcel."
        },
        "status": {
          "type": "string",
          "enum": ["En route", "En transit", "Arrivé", "Livré"],
          "description": "Current status of the parcel."
        },
        "currentLocation": {
          "type": "string",
          "description": "Current physical location of the parcel."
        },
        "estimatedArrival": {
          "type": "string",
          "format": "date-time",
          "description": "Estimated arrival date and time."
        },
        "proofOfDelivery": {
          "type": "string",
          "description": "URL of the delivery proof image."
        },
        "paymentStatus": {
          "type": "string",
          "enum": ["Payé", "Non payé"],
          "description": "Payment status of the parcel."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the parcel record was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the parcel record was last updated."
        }
      },
      "required": ["trackingNumber", "status", "currentLocation", "paymentStatus"]
    },
    "user": {
      "title": "User",
      "description": "Represents an administrator user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin"]
        }
      },
      "required": ["email", "role"]
    },
    "product": {
      "title": "Product",
      "description": "Represents a dynamic service or product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "whatsappMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "image", "description", "price"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global app settings like logo and official winners.",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "whatsappAdminNumber": { "type": "string" },
        "officialWinners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "points": { "type": "number" },
              "prize": { "type": "number" }
            }
          }
        }
      }
    },
    "affiliate": {
      "title": "Affiliate",
      "description": "Represents an affiliate user.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "referredClients": { "type": "number" },
        "monthlyReferredClients": { "type": "number" },
        "monthlySales": { "type": "number" },
        "points": { "type": "number" },
        "code": { "type": "string" },
        "level": { "type": "string", "enum": ["Bronze", "Silver", "Gold", "Elite", "VIP"] },
        "parentAffiliateId": { "type": "string" },
        "directRevenue": { "type": "number" },
        "indirectRevenue": { "type": "number" },
        "totalEarnings": { "type": "number" },
        "isMonthlyWinner": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "password", "name", "balance", "referredClients", "code", "level"]
    },
    "withdrawal": {
      "title": "Withdrawal",
      "description": "Represents a withdrawal request from an affiliate.",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string" },
        "affiliateName": { "type": "string" },
        "affiliateCode": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["MonCash", "NatCash", "Physical"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["affiliateId", "amount", "method", "status"]
    },
    "notification": {
      "title": "Notification",
      "description": "Represents a notification for an affiliate.",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["level_up", "bonus", "referral", "purchase", "revenue", "prize", "system"] },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["affiliateId", "title", "message", "type", "read"]
    },
    "affiliate_request": {
      "title": "Affiliate Request",
      "description": "Represents a registration request for the affiliate program.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "status"]
    },
    "game": {
      "title": "Game",
      "description": "Represents a game for top-up services.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "priceRange": { "type": "string" },
        "whatsappMessage": { "type": "string" },
        "catalog": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "price": { "type": "string" },
              "whatsappMessage": { "type": "string" }
            }
          }
        },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "image", "description", "priceRange"]
    },
    "card_topup": {
      "title": "Card Topup",
      "description": "Represents a card for recharge services.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "whatsappMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "image", "description", "price"]
    },
    "shipping_config": {
      "title": "Shipping Configuration",
      "description": "Configuration for Shipping options (Online Purchase and Drop Shipping).",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["online_purchase", "dropshipping"] },
        "addresses": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "city": { "type": "string", "description": "Name of the city for this address." },
              "text": { "type": "string" }
            }
          }
        },
        "websites": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "videos": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "title": { "type": "string" },
              "url": { "type": "string" }
            }
          }
        },
        "whatsappNumber": { "type": "string" },
        "whatsappMessage": { "type": "string" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["type", "addresses", "websites", "videos", "updatedAt"]
    },
    "slider_image": {
      "title": "Slider Image",
      "description": "Represents an image displayed in the home hero slider.",
      "type": "object",
      "properties": {
        "url": { "type": "string" },
        "title": { "type": "string", "description": "Title overlaid on the slide." },
        "description": { "type": "string", "description": "Description overlaid on the slide." },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["url", "createdAt"]
    },
    "nav_button": {
      "title": "Navigation Button",
      "description": "Represents a quick navigation button on the home page.",
      "type": "object",
      "properties": {
        "label": { "type": "string" },
        "iconName": { "type": "string" },
        "targetUrl": { "type": "string" },
        "redirectionInstruction": { "type": "string", "description": "Phrase dynamique pour la redirection." },
        "color": { "type": "string" },
        "order": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["label", "targetUrl", "iconName", "order"]
    },
    "admin_account": {
      "title": "Admin Account",
      "description": "Represents an administrator with custom login credentials and permissions.",
      "type": "object",
      "properties": {
        "fullName": { "type": "string" },
        "uid": { "type": "string", "description": "Firebase Auth UID for security rules." },
        "password": { "type": "string" },
        "photoUrl": { "type": "string", "description": "URL of the admin's profile picture." },
        "loginCode": { "type": "string" },
        "isSuperAdmin": { "type": "boolean" },
        "permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "failedAttempts": { "type": "number" },
        "lockUntil": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["fullName", "password", "permissions"]
    },
    "admin_login_log": {
      "title": "Admin Login Log",
      "description": "Represents a login attempt to the admin panel.",
      "type": "object",
      "properties": {
        "adminName": { "type": "string" },
        "success": { "type": "boolean" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" }
      },
      "required": ["adminName", "success", "timestamp"]
    }
  },
  "firestore": {
    "/parcels/{parcelId}": {
      "schema": "parcel",
      "description": "Collection of parcels."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of administrator users."
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Collection of dynamic products."
    },
    "/settings/{settingId}": {
      "schema": "settings",
      "description": "Global settings."
    },
    "/affiliates/{affiliateId}": {
      "schema": "affiliate",
      "description": "Collection of affiliates."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "withdrawal",
      "description": "Collection of withdrawal requests."
    },
    "/notifications/{notificationId}": {
      "schema": "notification",
      "description": "Collection of affiliate notifications."
    },
    "/affiliate_requests/{requestId}": {
      "schema": "affiliate_request",
      "description": "Collection of affiliate program registration requests."
    },
    "/games/{gameId}": {
      "schema": "game",
      "description": "Collection of games for top-up."
    },
    "/card_topups/{cardId}": {
      "schema": "card_topup",
      "description": "Collection of cards for recharge."
    },
    "/shipping_configs/{configId}": {
      "schema": "shipping_config",
      "description": "Collection of shipping configurations."
    },
    "/slider_images/{imageId}": {
      "schema": "slider_image",
      "description": "Collection of hero slider images."
    },
    "/nav_buttons/{buttonId}": {
      "schema": "nav_button",
      "description": "Collection of quick navigation buttons."
    },
    "/admin_accounts/{adminId}": {
      "schema": "admin_account",
      "description": "Collection of custom admin accounts."
    },
    "/admin_login_logs/{logId}": {
      "schema": "admin_login_log",
      "description": "Collection of admin login attempt logs."
    }
  }
}
