{
  "entities": {
    "parcel": {
      "title": "Parcel",
      "description": "Represents a parcel being tracked in the system.",
      "type": "object",
      "properties": {
        "trackingNumber": {
          "type": "string",
          "description": "Unique tracking number for the parcel."
        },
        "status": {
          "type": "string",
          "enum": ["En route", "En transit", "Arrivé", "Livré"],
          "description": "Current status of the parcel."
        },
        "currentLocation": {
          "type": "string",
          "description": "Current physical location of the parcel."
        },
        "estimatedArrival": {
          "type": "string",
          "format": "date-time",
          "description": "Estimated arrival date and time."
        },
        "proofOfDelivery": {
          "type": "string",
          "description": "URL of the delivery proof image."
        },
        "paymentStatus": {
          "type": "string",
          "enum": ["Payé", "Non payé"],
          "description": "Payment status of the parcel."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the parcel record was created."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the parcel record was last updated."
        }
      },
      "required": ["trackingNumber", "status", "currentLocation", "paymentStatus"]
    },
    "user": {
      "title": "User",
      "description": "Represents an administrator user.",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "format": "email"
        },
        "role": {
          "type": "string",
          "enum": ["admin"]
        }
      },
      "required": ["email", "role"]
    },
    "product": {
      "title": "Product",
      "description": "Represents a dynamic service or product.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "string" },
        "whatsappMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "image", "description", "price"]
    },
    "settings": {
      "title": "Settings",
      "description": "Global app settings like logo and official winners.",
      "type": "object",
      "properties": {
        "logoUrl": { "type": "string" },
        "whatsappAdminNumber": { "type": "string" },
        "officialWinners": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "id": { "type": "string" },
              "name": { "type": "string" },
              "points": { "type": "number" },
              "prize": { "type": "number" }
            }
          }
        }
      }
    },
    "affiliate": {
      "title": "Affiliate",
      "description": "Represents an affiliate user.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "balance": { "type": "number" },
        "referredClients": { "type": "number" },
        "code": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "password", "name", "balance", "referredClients", "code"]
    },
    "withdrawal": {
      "title": "Withdrawal",
      "description": "Represents a withdrawal request from an affiliate.",
      "type": "object",
      "properties": {
        "affiliateId": { "type": "string" },
        "affiliateName": { "type": "string" },
        "affiliateCode": { "type": "string" },
        "amount": { "type": "number" },
        "method": { "type": "string", "enum": ["MonCash", "Natcash"] },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "rejectionReason": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["affiliateId", "amount", "method", "status"]
    },
    "admin": {
      "title": "Admin",
      "description": "Represents an administrator with specific permissions.",
      "type": "object",
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "parcel_manager", "affiliate_manager", "settings_manager"] },
        "permissions": {
          "type": "array",
          "items": { "type": "string" }
        },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["username", "password", "name", "role"]
    },
    "game": {
      "title": "Game",
      "description": "Represents a game for top-up services.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "image": { "type": "string" },
        "description": { "type": "string" },
        "priceRange": { "type": "string" },
        "whatsappMessage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "image", "description", "priceRange"]
    },
    "affiliate_request": {
      "title": "Affiliate Request",
      "description": "Represents a request to join the affiliate program.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "email", "phone", "status"]
    }
  },
  "firestore": {
    "/parcels/{parcelId}": {
      "schema": "parcel",
      "description": "Collection of parcels."
    },
    "/users/{userId}": {
      "schema": "user",
      "description": "Collection of administrator users."
    },
    "/products/{productId}": {
      "schema": "product",
      "description": "Collection of dynamic products."
    },
    "/settings/{settingId}": {
      "schema": "settings",
      "description": "Global settings."
    },
    "/affiliates/{affiliateId}": {
      "schema": "affiliate",
      "description": "Collection of affiliates."
    },
    "/withdrawals/{withdrawalId}": {
      "schema": "withdrawal",
      "description": "Collection of withdrawal requests."
    },
    "/affiliate_requests/{requestId}": {
      "schema": "affiliate_request",
      "description": "Collection of requests to join the affiliate program."
    },
    "/admins/{adminId}": {
      "schema": "admin",
      "description": "Collection of administrators."
    },
    "/games/{gameId}": {
      "schema": "game",
      "description": "Collection of games for top-up."
    }
  }
}
