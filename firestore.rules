rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: parcels
    // Document ID: auto-generated
    // Fields:
    //   - trackingNumber: string (required) - Unique tracking number
    //   - status: string (required, enum) - En route, En transit, Arrivé, Livré
    //   - currentLocation: string (required) - Current location
    //   - estimatedArrival: string (optional, ISO8601) - Estimated arrival date
    //   - proofOfDelivery: string (optional, URL) - Image URL
    //   - paymentStatus: string (required, enum) - Payé, Non payé
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum) - admin
    //
    // ===============================================================

    // Collection: admins
    // Document ID: userId (auth.uid)
    // Fields:
    //   - username: string (required)
    //   - name: string (required)
    //   - role: string (required, enum) - super_admin, parcel_manager, affiliate_manager, settings_manager
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
          request.auth.token.email == "ernstisrael2000@gmail.com"
        );
    }

    function getAdminData() {
      return get(/databases/$(database)/documents/admins/$(request.auth.uid)).data;
    }

    function isSuperAdmin() {
      return isAdmin() && (
        request.auth.token.email == "ernstisrael2000@gmail.com" ||
        (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
         getAdminData().role == 'super_admin')
      );
    }

    function canManageParcels() {
      return isSuperAdmin() || (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
                                getAdminData().role == 'parcel_manager');
    }

    function canManageAffiliates() {
      return isSuperAdmin() || (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
                                getAdminData().role == 'affiliate_manager');
    }

    function canManageSettings() {
      return isSuperAdmin() || (exists(/databases/$(database)/documents/admins/$(request.auth.uid)) && 
                                getAdminData().role == 'settings_manager');
    }

    function isValidAffiliate(data) {
      return data.keys().hasAll(['name', 'username', 'password', 'code']) &&
             data.name is string && data.name.size() > 0 &&
             data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             (!('balance' in data) || data.balance is number) &&
             (!('referredClients' in data) || data.referredClients is number);
    }

    function isValidParcel(data) {
      return data.keys().hasAll(['trackingNumber', 'status', 'currentLocation', 'paymentStatus']) &&
             data.trackingNumber is string && data.trackingNumber.size() > 0 && data.trackingNumber.size() < 100 &&
             data.status in ['En route', 'En transit', 'Arrivé', 'Livré'] &&
             data.currentLocation is string && data.currentLocation.size() < 200 &&
             data.paymentStatus in ['Payé', 'Non payé'] &&
             (!('proofOfDelivery' in data) || (data.proofOfDelivery is string && data.proofOfDelivery.size() < 1000)) &&
             (!('estimatedArrival' in data) || (data.estimatedArrival is string));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'price']) &&
             data.name is string && data.name.size() > 0 &&
             data.image is string &&
             data.description is string &&
             data.price is string;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'priceRange']) &&
             data.name is string && data.name.size() > 0 &&
             data.image is string &&
             data.description is string &&
             data.priceRange is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /parcels/{parcelId} {
      allow read: if true; 
      allow create: if canManageParcels() && isValidParcel(request.resource.data);
      allow update: if canManageParcels() && isValidParcel(request.resource.data);
      allow delete: if canManageParcels();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if canManageSettings() && isValidProduct(request.resource.data);
      allow update: if canManageSettings() && isValidProduct(request.resource.data);
      allow delete: if canManageSettings();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if canManageSettings();
    }

    match /affiliates/{affiliateId} {
      allow read: if true; 
      allow create: if canManageAffiliates() && isValidAffiliate(request.resource.data);
      allow update: if canManageAffiliates() && isValidAffiliate(request.resource.data);
      allow delete: if canManageAffiliates();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if canManageAffiliates(); 
      allow delete: if canManageAffiliates();
    }

    match /affiliate_requests/{requestId} {
      allow read: if canManageAffiliates();
      allow create: if true; 
      allow update: if canManageAffiliates();
      allow delete: if canManageAffiliates();
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if canManageSettings() && isValidGame(request.resource.data);
      allow update: if canManageSettings() && isValidGame(request.resource.data);
      allow delete: if canManageSettings();
    }

    match /admins/{adminId} {
      allow read: if isAdmin();
      allow write: if isSuperAdmin();
    }

    match /users/{userId} {
      allow read: if isAuthenticated() && request.auth.uid == userId;
      allow write: if isSuperAdmin();
    }
  }
}
