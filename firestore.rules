rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: parcels
    // Document ID: auto-generated
    // Fields:
    //   - trackingNumber: string (required) - Unique tracking number
    //   - status: string (required, enum) - En route, En transit, Arrivé, Livré
    //   - currentLocation: string (required) - Current location
    //   - estimatedArrival: string (optional, ISO8601) - Estimated arrival date
    //   - proofOfDelivery: string (optional, URL) - Image URL
    //   - paymentStatus: string (required, enum) - Payé, Non payé
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum) - admin
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          (request.auth.token.email in ["ernstisrael2000@gmail.com", "ernstisrael508@gmail.com"])
        );
    }

    function isValidAffiliate(data) {
      return data.keys().hasAll(['name', 'username', 'password', 'code', 'level']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.password is string && data.password.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             data.level in ['Bronze', 'Silver', 'Gold', 'Elite', 'VIP'] &&
             (!('balance' in data) || data.balance is number) &&
             (!('points' in data) || data.points is number);
    }

    function isValidParcel(data) {
      return data.keys().hasAll(['trackingNumber', 'status', 'currentLocation', 'paymentStatus']) &&
             data.trackingNumber is string && data.trackingNumber.size() > 0 && data.trackingNumber.size() < 100 &&
             data.status in ['En route', 'En transit', 'Arrivé', 'Livré'] &&
             data.currentLocation is string && data.currentLocation.size() < 200 &&
             data.paymentStatus in ['Payé', 'Non payé'] &&
             (!('proofOfDelivery' in data) || (data.proofOfDelivery is string && data.proofOfDelivery.size() < 1000)) &&
             (!('estimatedArrival' in data) || (data.estimatedArrival is string));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'image', 'description']) && 
             data.name is string && data.name.size() > 0;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['name', 'image', 'description']) &&
             data.name is string && data.name.size() > 0 &&
             (!('catalog' in data) || data.catalog is list);
    }

    function isValidCard(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'price']) &&
             data.name is string && data.name.size() > 0 &&
             data.price is string && data.price.size() > 0;
    }

    function isValidWithdrawal(data) {
      return data.keys().hasAll(['affiliateId', 'amount', 'method', 'status']) &&
             data.affiliateId is string &&
             data.amount is number && data.amount >= 20 &&
             data.method in ['MonCash', 'NatCash', 'Physical'] &&
             data.status in ['pending', 'approved', 'rejected'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /parcels/{parcelId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidParcel(request.resource.data);
      allow update: if isAdmin() && isValidParcel(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGame(request.resource.data);
      allow update: if isAdmin() && isValidGame(request.resource.data);
      allow delete: if isAdmin();
    }

    match /card_topups/{cardId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCard(request.resource.data);
      allow update: if isAdmin() && isValidCard(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidAffiliate(request.resource.data);
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'referredClients', 'points', 'monthlyReferredClients', 'monthlySales', 'isMonthlyWinner', 'updatedAt', 'level', 'directRevenue', 'indirectRevenue', 'totalEarnings']));
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true; 
      allow create: if isValidWithdrawal(request.resource.data); 
      allow update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    match /affiliate_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; 
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if true;
      allow delete: if isAdmin();
    }

    match /shipping_configs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /slider_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Only admins can manage users (or the system bootstraps the first admin)
      allow write: if isAdmin();
    }
  }
}
