rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: parcels
    // Document ID: auto-generated
    // Fields:
    //   - trackingNumber: string (required) - Unique tracking number
    //   - status: string (required, enum) - En route, En transit, Arrivé, Livré
    //   - currentLocation: string (required) - Current location
    //   - estimatedArrival: string (optional, ISO8601) - Estimated arrival date
    //   - proofOfDelivery: string (optional, URL) - Image URL
    //   - paymentStatus: string (required, enum) - Payé, Non payé
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum) - admin
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        (
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
          request.auth.token.email == "ernstisrael2000@gmail.com"
        );
    }

    function isValidAffiliate(data) {
      return data.keys().hasAll(['name', 'username', 'password', 'code']) &&
             data.name is string && data.name.size() > 0 &&
             data.username is string && data.username.size() > 0 &&
             data.password is string && data.password.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             (!('balance' in data) || data.balance is number) &&
             (!('referredClients' in data) || data.referredClients is number);
    }

    function isValidParcel(data) {
      return data.keys().hasAll(['trackingNumber', 'status', 'currentLocation', 'paymentStatus']) &&
             data.trackingNumber is string && data.trackingNumber.size() > 0 && data.trackingNumber.size() < 100 &&
             data.status in ['En route', 'En transit', 'Arrivé', 'Livré'] &&
             data.currentLocation is string && data.currentLocation.size() < 200 &&
             data.paymentStatus in ['Payé', 'Non payé'] &&
             (!('proofOfDelivery' in data) || (data.proofOfDelivery is string && data.proofOfDelivery.size() < 1000)) &&
             (!('estimatedArrival' in data) || (data.estimatedArrival is string));
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'price']) &&
             data.name is string && data.name.size() > 0 &&
             data.image is string &&
             data.description is string &&
             data.price is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /parcels/{parcelId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidParcel(request.resource.data);
      allow update: if isAdmin() && isValidParcel(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidAffiliate(request.resource.data);
      allow update: if isAdmin() && isValidAffiliate(request.resource.data);
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true; // Allow affiliates to see their requests and admins to see all
      allow create: if true; // Affiliates can create requests
      allow update: if isAdmin(); // Only admins can approve/reject
      allow delete: if isAdmin();
    }

    match /affiliate_requests/{requestId} {
      allow read: if isAdmin();
      allow create: if true; // Public can request to join
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isAuthenticated() && request.auth.uid == userId;
      
      // Only admins can manage users (or the system bootstraps the first admin)
      allow write: if isAdmin();
    }
  }
}
