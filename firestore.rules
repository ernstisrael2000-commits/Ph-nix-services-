rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: parcels
    // Document ID: auto-generated
    // Fields:
    //   - trackingNumber: string (required) - Unique tracking number
    //   - status: string (required, enum) - En route, En transit, Arrivé, Livré
    //   - currentLocation: string (required) - Current location
    //   - estimatedArrival: string (optional, ISO8601) - Estimated arrival date
    //   - proofOfDelivery: string (optional, URL) - Image URL
    //   - paymentStatus: string (required, enum) - Payé, Non payé
    //   - createdAt: timestamp (required)
    //   - updatedAt: timestamp (required)
    //
    // Collection: users
    // Document ID: userId (auth.uid)
    // Fields:
    //   - email: string (required)
    //   - role: string (required, enum) - admin
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }

    function isEmailAuthorizedAdmin() {
      return isAuthenticated() && 
        request.auth.token.email != null && (
          request.auth.token.email.lower() == "ernstisrael2000@gmail.com" ||
          request.auth.token.email.lower() == "ernstisrael508@gmail.com" ||
          request.auth.token.email.lower() == "admin@neopay.com"
        );
    }

    function isAdmin() {
      return isEmailAuthorizedAdmin() || 
             (isAuthenticated() && exists(/databases/$(database)/documents/admin_uids/$(request.auth.uid)));
    }

    function isAgent() {
      return isAuthenticated() &&
        (
          exists(/databases/$(database)/documents/agents/$(request.auth.uid)) ||
          (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "agent")
        );
    }

    function isValidClient(data) {
      return data.keys().hasAll(['name', 'phone']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.phone is string && data.phone.size() > 0 && data.phone.size() < 30;
    }

    function isValidAgent(data) {
      return data.keys().hasAll(['agentCode', 'name', 'phone', 'balance', 'status']) &&
             data.agentCode is string &&
             data.name is string &&
             data.phone is string &&
             data.balance is number &&
             data.status in ['active', 'inactive'];
    }

    function isValidAffiliate(data) {
      return data.keys().hasAll(['name', 'username', 'password', 'code', 'level']) &&
             data.name is string && data.name.size() > 0 && data.name.size() < 100 &&
             data.username is string && data.username.size() > 0 && data.username.size() < 50 &&
             data.password is string && data.password.size() > 0 &&
             data.code is string && data.code.size() > 0 &&
             data.level in ['Bronze', 'Silver', 'Gold', 'Elite', 'VIP'];
    }

    function isValidParcel(data) {
      return data.keys().hasAll(['trackingNumber', 'status', 'currentLocation', 'paymentStatus']) &&
             data.trackingNumber is string && data.trackingNumber.size() > 0 && data.trackingNumber.size() < 100 &&
             data.status in ['En route', 'En transit', 'Arrivé', 'Livré', 'En attente', 'Pickup'] &&
             data.currentLocation is string && data.paymentStatus is string;
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'image', 'description']) && 
             data.name is string && data.name.size() > 0 && data.image is string;
    }

    function isValidGame(data) {
      return data.keys().hasAll(['name', 'image', 'description']) && 
             data.name is string && data.name.size() > 0 && data.image is string;
    }

    function isValidCard(data) {
      return data.keys().hasAll(['name', 'image', 'description', 'price']) && 
             data.name is string && data.name.size() > 0 && data.price is string;
    }

    function isValidStatus(status) {
      return status in ['pending', 'approved', 'rejected', 'completed'];
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /wallet_transactions/{transactionId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    match /agents/{agentId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin() || (isAgent() && request.auth.uid == agentId);
      allow delete: if isAdmin();
    }

    match /clients/{clientId} {
      allow read: if true;
      allow create: if true; 
      allow update: if true; // Allow client to self-update ID or status if needed during registration
      allow delete: if isAdmin();
    }

    match /parcels/{parcelId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidParcel(request.resource.data);
      allow update: if isAdmin() && isValidParcel(request.resource.data);
      allow delete: if isAdmin();
    }

    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidProduct(request.resource.data);
      allow update: if isAdmin() && isValidProduct(request.resource.data);
      allow delete: if isAdmin();
    }

    match /games/{gameId} {
      allow read: if true;
      allow create: if isAdmin() && isValidGame(request.resource.data);
      allow update: if isAdmin() && isValidGame(request.resource.data);
      allow delete: if isAdmin();
    }

    match /card_topups/{cardId} {
      allow read: if true;
      allow create: if isAdmin() && isValidCard(request.resource.data);
      allow update: if isAdmin() && isValidCard(request.resource.data);
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /affiliates/{affiliateId} {
      allow read: if true; 
      allow create: if isAdmin() && isValidAffiliate(request.resource.data);
      allow update: if isAdmin() || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['balance', 'referredClients', 'points', 'monthlyReferredClients', 'monthlySales', 'isMonthlyWinner', 'updatedAt', 'level', 'directRevenue', 'indirectRevenue', 'totalEarnings', 'totalWithdrawn', 'walletId']));
      allow delete: if isAdmin();
    }

    match /withdrawals/{withdrawalId} {
      allow read: if true; 
      allow create: if true; 
      allow update: if isAdmin(); 
      allow delete: if isAdmin();
    }

    match /affiliate_requests/{requestId} {
      allow read: if isAuthenticated();
      allow create: if true; 
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /notifications/{notificationId} {
      allow read: if true;
      allow create: if true;
      allow update: if true;
      allow delete: if isAdmin();
    }

    match /shipping_configs/{configId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /slider_images/{imageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /nav_buttons/{buttonId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admin_accounts/{adminId} {
      allow read: if true;
      allow update: if isAdmin() || (
        isAuthenticated() && 
        (resource.data.uid == null || resource.data.uid == "" || resource.data.uid == request.auth.uid) &&
        (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['uid', 'failedAttempts', 'lockUntil', 'updatedAt']))
      );
      allow create: if isAdmin() || isEmailAuthorizedAdmin();
      allow delete: if isAdmin();
    }

    match /admin_uids/{uid} {
      allow read: if true;
      allow write: if isAdmin() || (isAuthenticated() && request.auth.uid == uid);
    }

    match /admin_login_logs/{logId} {
      allow create: if true;
      allow read: if isAdmin();
    }

    match /client_transactions/{transactionId} {
      allow read: if true;
      allow create: if true;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /users/{userId} {
      // Users can only read their own profile
      allow read: if isAuthenticated() && (request.auth.uid == userId || isAdmin());
      
      // Only admins can manage users (or the system bootstraps the first admin)
      allow write: if isAdmin();
    }

    match /sales/{saleId} {
      allow read: if isAdmin();
      allow create: if true; // Sales can be recorded via batch/client
      allow delete: if isAdmin();
    }

    match /_connection_test_/{docId} {
      allow read: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
