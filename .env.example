# ── Firebase Admin (OBLIGATOIRE) ──────────────────────────────────────────────
# JSON du compte de service Firebase — depuis Firebase Console
# > Project Settings > Service Accounts > Generate New Private Key
# Peut être fourni tel quel (JSON brut) ou encodé en base64
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ── Email SMTP — Gmail (OPTIONNEL) ────────────────────────────────────────────
# Adresse Gmail utilisée pour les notifications administrateur
SMTP_USER=votre-email@gmail.com
# Mot de passe d'application Gmail (pas votre mot de passe principal)
# Générer depuis : Compte Google > Sécurité > Mots de passe des applications
SMTP_PASS=xxxx-xxxx-xxxx-xxxx

# ── Google reCAPTCHA v2 (OPTIONNEL) ──────────────────────────────────────────
# Clé secrète depuis : https://www.google.com/recaptcha/admin
RECAPTCHA_SECRET_KEY=6Le...
# Clé publique pour le frontend (exposée dans Vite via vite.config.ts)
RECAPTCHA_SITE_KEY=6Le...

# ── Push Notifications VAPID (OPTIONNEL) ──────────────────────────────────────
# Générer avec : npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=BJbF5eX...
VAPID_PRIVATE_KEY=abc123...

# ── Serveur (OPTIONNEL) ───────────────────────────────────────────────────────
# Port d'écoute (défaut: 5000 en dev, injecté automatiquement sur Railway/Render)
PORT=5000
